<group name="custom_soc_lab,authentication,brute_force">

  <!-- ================================================================
       Rule 100001: SSH Brute Force Detection
       Triggers when more than 5 failed SSH attempts occur within 60s
       MITRE ATT&CK: T1110 - Brute Force
  ================================================================ -->
  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5716</if_matched_sid>
    <same_source_ip />
    <description>SOC Lab: Multiple failed SSH login attempts from $(srcip) - Possible brute force</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,brute_force,high_severity</group>
  </rule>

  <!-- ================================================================
       Rule 100003: Successful login after brute force
       Triggers when a successful login follows failed attempts
       MITRE ATT&CK: T1110.001 - Password Guessing
  ================================================================ -->
  <rule id="100003" level="14" frequency="3" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <if_sid>5715</if_sid>
    <same_source_ip />
    <description>SOC Lab: CRITICAL - Successful login after brute force from $(srcip) - Possible compromise</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>brute_force,compromise,critical</group>
  </rule>

  <!-- ================================================================
       Rule 100004: RDP Brute Force (Windows Event ID 4625)
       MITRE ATT&CK: T1110 - Brute Force
  ================================================================ -->
  <rule id="100004" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_source_ip />
    <description>SOC Lab: Multiple failed RDP login attempts from $(srcip) - Possible RDP brute force</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,brute_force,rdp</group>
  </rule>

</group>
